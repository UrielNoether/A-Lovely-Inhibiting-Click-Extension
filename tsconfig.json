{
  "include": [
    "node_modules/bc-stubs/bc/**/*.d.ts",
    "**/*.js",
    "**/*.ts"
  ],
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowJs": false,
    "removeComments": true,
    "sourceMap": true,
    "alwaysStrict": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": false,  // Changed from true to allow esbuild to emit
    "baseUrl": "./",   // Changed from "src" to root
    "paths": {
      "@/*": ["src/*"],
      "@/modules/*": ["src/modules/*"],
      "@/subscreens/*": ["src/subscreens/*"]
    }
  }
}
